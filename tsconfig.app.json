{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,
    "strict": false,
    "checkJs": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
